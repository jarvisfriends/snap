{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go: build",
      "type": "shell",
      "command": "go build ./...",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "go: test",
      "type": "shell",
      "command": "go test ./... -v",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "go: test (race)",
      "type": "shell",
      "command": "go test -race ./... -v",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "go: lint",
      "type": "shell",
      "command": "golangci-lint run ./...",
      "problemMatcher": []
    },
    {
      "label": "go: vet",
      "type": "shell",
      "command": "go vet ./...",
      "problemMatcher": []
    },
    {
      "label": "go: verify local",
      "type": "shell",
      "command": "bash tools/local_verify.sh",
      "problemMatcher": []
    }
  ]
}